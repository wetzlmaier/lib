<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    x:Class="Scch.Mvvm.View.ModalDialogView"
    xmlns:design="clr-namespace:Scch.Mvvm.Design"
    mc:Ignorable="d" d:DesignWidth="209.007" d:DesignHeight="217.96" 
    d:DataContext="{d:DesignInstance Type=design:ModalDialogViewModelDesignData, IsDesignTimeCreatable=True}"
    xmlns:Markup="clr-namespace:Scch.Common.Windows.Markup;assembly=Scch.Common"
    FocusManager.FocusedElement="{Markup:FirstFocusedElement}">

    <StackPanel>
        <ContentPresenter Name="content" Content="{Binding Content}" Margin="8">
            
        </ContentPresenter>
        
        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" DockPanel.Dock="Bottom" FlowDirection="RightToLeft">
            <Button DataContext="{Binding CancelCommand}" HorizontalAlignment="Right" Margin="8,0,8,8" VerticalAlignment="Bottom" MinWidth="50"
                    Content="{Binding DisplayName}" Command="{Binding Command}" IsCancel="True"/>
            <Button DataContext ="{Binding OkCommand}" HorizontalAlignment="Right" Margin="0,0,8,8" VerticalAlignment="Bottom" MinWidth="50"
                    Content="{Binding DisplayName}" Command="{Binding Command}" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</UserControl>
