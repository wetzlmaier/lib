<Window x:Class="Scch.Controls.Mvvm.View.ConsoleView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:design="clr-namespace:Scch.Controls.Mvvm.Design;assembly=Scch.Controls.Mvvm"
        xmlns:controls="clr-namespace:Scch.Controls;assembly=Scch.Controls"
        xmlns:windows="clr-namespace:Scch.Common.Windows;assembly=Scch.Common"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d" d:DataContext="{d:DesignInstance Type=design:ConsoleViewDesignData, IsDesignTimeCreatable=True}"
        Title="{Binding DisplayName}" Icon="{Binding Icon}" Height="768" Width="1024">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Scch.Controls;component/themes/generic.xaml" />
                <ResourceDictionary>
                    <ContextMenu x:Key="ContextMenu">
                        <MenuItem DataContext="{Binding Output.UndoCommand}" Style="{StaticResource MenuWithIcon}"/>
                        <MenuItem DataContext="{Binding Output.RedoCommand}" Style="{StaticResource MenuWithIcon}"/>
                        <Separator />
                        <MenuItem DataContext="{Binding Output.CutCommand}" Style="{StaticResource MenuWithIcon}"/>
                        <MenuItem DataContext="{Binding Output.CopyCommand}" Style="{StaticResource MenuWithIcon}"/>
                        <MenuItem DataContext="{Binding Output.PasteCommand}" Style="{StaticResource MenuWithIcon}"/>
                    </ContextMenu>

                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Loaded" >
            <b:InvokeCommandAction Command="{Binding LoadedCommand}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>
    <Grid>
        <controls:BindableRichTextBox Name="Editor" AcceptsTab="False" Document="{Binding Output.Document, UpdateSourceTrigger=PropertyChanged}" 
                     IsManipulationEnabled="False" IsDocumentEnabled="False" IsReadOnly="True" ContextMenu="{StaticResource ContextMenu}" Selection="{Binding Output.Selection}" 
                                      Background="Black" CaretPosition="{Binding Output.CaretPosition, Mode=TwoWay}" Styles="{Binding Output.Styles}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <b:Interaction.Triggers>
                <b:EventTrigger EventName="TextChanged">
                    <b:InvokeCommandAction Command="{Binding Output.TextChanged}" />
                </b:EventTrigger>
                <b:EventTrigger EventName="TextChanged">
                    <windows:RichTextBoxScrollToEndTriggerAction />
                </b:EventTrigger>
            </b:Interaction.Triggers>

        </controls:BindableRichTextBox>
    </Grid>
</Window>
