<UserControl x:Class="Scch.Controls.Mvvm.View.TablePropertiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:design="clr-namespace:Scch.Controls.Mvvm.Design"
             mc:Ignorable="d" d:DesignHeight="260" d:DesignWidth="320" MinWidth="250" MinHeight="60"
             d:DataContext="{d:DesignInstance Type=design:TablePropertiesViewDesignData, IsDesignTimeCreatable=True}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="..\DataTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="120"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <Label Content="{Binding DisplayNames[ColumnCount]}" Target="{Binding ElementName=txtColumnCount}" HorizontalAlignment="Stretch" 
               VerticalAlignment="Stretch" HorizontalContentAlignment="Left" Grid.Column="0" Grid.Row="0" />
        <TextBox x:Name="txtColumnCount" Text="{Binding Path=ColumnCount, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=true, ValidatesOnDataErrors=true, NotifyOnValidationError=true}"
                  Validation.ErrorTemplate="{x:Null}" Grid.Column="1" Grid.Row="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" />
        <ContentPresenter Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Content="{Binding ElementName=txtColumnCount, Path=(Validation.Errors).CurrentItem}" HorizontalAlignment="Right" />

        <Label Content="{Binding DisplayNames[RowCount]}" Target="{Binding ElementName=txtRowCount}" HorizontalAlignment="Stretch" 
               VerticalAlignment="Stretch" HorizontalContentAlignment="Left" Grid.Column="0" Grid.Row="2" />
        <TextBox x:Name="txtRowCount" Text="{Binding Path=RowCount, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=true, ValidatesOnDataErrors=true, NotifyOnValidationError=true}"
                  Validation.ErrorTemplate="{x:Null}" Grid.Column="1" Grid.Row="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" />
        <ContentPresenter Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="3" Content="{Binding ElementName=txtRowCount, Path=(Validation.Errors).CurrentItem}" HorizontalAlignment="Right" />

        <DockPanel Grid.Column="0" Grid.Row="4" HorizontalAlignment="Stretch">
            <Label Content="{Binding DisplayNames[ColumnWidth]}" Target="{Binding ElementName=txtColumnWidth}" HorizontalAlignment="Stretch" 
               VerticalAlignment="Stretch" HorizontalContentAlignment="Left" Grid.Column="0" Grid.Row="4" />
            <CheckBox x:Name="chkAutoWidth" Content="{Binding DisplayNames[AutoWidth]}" VerticalAlignment="Center" DockPanel.Dock="Right" Margin="5" HorizontalAlignment="Right" />
        </DockPanel>
        <TextBox x:Name="txtColumnWidth" Text="{Binding Path=ColumnWidth, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=true, ValidatesOnDataErrors=true, NotifyOnValidationError=true}"
                      Validation.ErrorTemplate="{x:Null}" Grid.Column="1" Grid.Row="4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" />
        <ContentPresenter Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="5" Content="{Binding ElementName=txtColumnWidth, Path=(Validation.Errors).CurrentItem}" HorizontalAlignment="Right" />

        <Label Content="{Binding DisplayNames[BorderBrush]}" Target="{Binding ElementName=cbBorderBrush}" HorizontalAlignment="Stretch" 
               VerticalAlignment="Stretch" HorizontalContentAlignment="Left" Grid.Column="0" Grid.Row="6" />
        <ComboBox x:Name="cbBorderBrush" SelectedValue="{Binding Path=BorderBrush, Mode=TwoWay, ValidatesOnExceptions=true, ValidatesOnDataErrors=true, NotifyOnValidationError=true}"
                  Validation.ErrorTemplate="{x:Null}" Grid.Column="1" Grid.Row="6" HorizontalAlignment="Stretch" 
                  ItemTemplate="{StaticResource BrushInfoTemplate}" ItemsSource="{Binding Source={StaticResource GetBrushes}}" SelectedValuePath="Brush" />
        <ContentPresenter Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="7" Content="{Binding ElementName=cbBorderBrush, Path=(Validation.Errors).CurrentItem}" HorizontalAlignment="Right" />

        <Label Content="{Binding DisplayNames[BorderThickness]}" Target="{Binding ElementName=cbBorderThickness}" HorizontalAlignment="Stretch" 
               VerticalAlignment="Stretch" HorizontalContentAlignment="Left" Grid.Column="0" Grid.Row="8" />
        <ComboBox x:Name="cbBorderThickness" SelectedItem="{Binding Path=BorderThickness,  ValidatesOnExceptions=true, ValidatesOnDataErrors=true, NotifyOnValidationError=true}"
                  Validation.ErrorTemplate="{x:Null}" Grid.Column="1" Grid.Row="8" HorizontalAlignment="Stretch" 
                  ItemTemplate="{StaticResource ThicknessTemplate}" ItemsSource="{Binding Source={StaticResource GetThicknesses}}" >
        </ComboBox>
        <ContentPresenter Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="9" Content="{Binding ElementName=cbBorderThickness, Path=(Validation.Errors).CurrentItem}" HorizontalAlignment="Right" />

    </Grid>
</UserControl>
