<UserControl x:Class="Scch.Controls.CollectionEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:properties="clr-namespace:Scch.Controls.Properties"
             xmlns:imaging="clr-namespace:Scch.Common.Windows.Media.Imaging;assembly=Scch.Common"
             xmlns:controls="clr-namespace:Scch.Controls"
             mc:Ignorable="d" d:DesignHeight="362" d:DesignWidth="610" Focusable="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <imaging:BitmapToImageSourceConverter x:Key="bitmapToImageSourceConverter"/>
                </ResourceDictionary>
                <ResourceDictionary Source="Themes\generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Label Grid.Column="0" Grid.Row="0" x:Name="lblAvailableItemsHeader" />
        <Label Grid.Column="2" Grid.Row="0" x:Name="lblSelectedItemsHeader" />
        <controls:SortableListView x:Name="lvAvailableItems" Grid.Column="0" Grid.Row="1" HorizontalAlignment="Stretch" SelectionChanged="AvailableItemsSelectionChanged" MouseDoubleClick="AvailableItemsMouseDoubleClick">
            <ListView.View>
                <GridView x:Name="gvAvailableItems" />
            </ListView.View>
        </controls:SortableListView>

        <Grid Grid.Column="1" Grid.Row="1" VerticalAlignment="Center">
            <StackPanel Orientation="Vertical" >
                <Button x:Name="btnAddAll" Margin="5" ToolTip="{x:Static properties:Resources.CommonCommands_AddAllToolTip}">
                    <controls:AutoGreyableImage Height="32" Width="32" Source="{Binding Source={x:Static properties:Resources.AddAll_64x64}, Converter={StaticResource bitmapToImageSourceConverter}}" />
                </Button>
                <Button x:Name="btnAdd" Margin="5" ToolTip="{x:Static properties:Resources.CommonCommands_AddToolTip}">
                    <controls:AutoGreyableImage Height="32" Width="32" Source="{Binding Source={x:Static properties:Resources.Add_64x64}, Converter={StaticResource bitmapToImageSourceConverter}}" />
                </Button>
                <Button x:Name="btnRemove" Margin="5" ToolTip="{x:Static properties:Resources.CommonCommands_RemoveToolTip}">
                    <controls:AutoGreyableImage Height="32" Width="32" Source="{Binding Source={x:Static properties:Resources.Remove_64x64}, Converter={StaticResource bitmapToImageSourceConverter}}" />
                </Button>
                <Button x:Name="btnRemoveAll" Margin="5" ToolTip="{x:Static properties:Resources.CommonCommands_RemoveAllToolTip}">
                    <controls:AutoGreyableImage Height="32" Width="32" Source="{Binding Source={x:Static properties:Resources.RemoveAll_64x64}, Converter={StaticResource bitmapToImageSourceConverter}}" />
                </Button>
            </StackPanel>
        </Grid>

        <controls:SortableListView x:Name="lvSelectedItems" Grid.Column="2" Grid.Row="1" HorizontalAlignment="Stretch" SelectionChanged="SelectedItemsSelectionChanged" MouseDoubleClick="SelectedItemsMouseDoubleClick">
            <ListView.View>
                <GridView x:Name="gvSelectedItems" />
            </ListView.View>
        </controls:SortableListView>

        <Grid Grid.Column="3" Grid.Row="1" VerticalAlignment="Top">
            <controls:ListBoxSorter x:Name="sorter" Target="{Binding ElementName=lvSelectedItems}" />
                <!--
            <StackPanel x:Name="pnlSorting" Orientation="Vertical">
                <Button x:Name="btnMoveUp" Margin="5" ToolTip="{x:Static Properties:Resources.CommonCommands_MoveUpToolTip}">
                    <ctl:AutoGreyableImage Source="{Binding Source={x:Static Properties:Resources.MoveUp_32x32}, Converter={StaticResource bitmapToImageSourceConverter}}" />
                </Button>
                <Button x:Name="btnMoveDown" Margin="5" ToolTip="{x:Static Properties:Resources.CommonCommands_MoveDownToolTip}">
                    <ctl:AutoGreyableImage Source="{Binding Source={x:Static Properties:Resources.MoveDown_32x32}, Converter={StaticResource bitmapToImageSourceConverter}}" />
                </Button>
            </StackPanel>
            -->
        </Grid>

    </Grid>
</UserControl>
